import base64
import hashlib
from cryptography.fernet import Fernet


# Генерація ключа
def generate_key_from_personal_data(email: str, phrase: str) -> bytes:
    """
    Генерує симетричний ключ на основі персональних даних.
    Використовується SHA-256.
    """
    source = (email + phrase).encode("utf-8")
    digest = hashlib.sha256(source).digest()
    return base64.urlsafe_b64encode(digest)


# Шифрування
def encrypt_message(message: str, key: bytes) -> str:
    f = Fernet(key)
    encrypted = f.encrypt(message.encode("utf-8"))
    return encrypted.decode("utf-8")


# Розшифрування
def decrypt_message(token: str, key: bytes) -> str:
    f = Fernet(key)
    decrypted = f.decrypt(token.encode("utf-8"))
    return decrypted.decode("utf-8")


# Меню
def menu():
    print("\n=== Email-шифратор (AES, симетричне шифрування) ===")
    print("1) Зашифрувати повідомлення")
    print("2) Розшифрувати повідомлення")
    print("3) Вийти")


def main():
    while True:
        menu()
        choice = input("Обери (1-3): ").strip()

        if choice == "1":
            email = input("Введіть електронну адресу: ")
            phrase = input("Введіть секретну фразу (пароль): ")
            message = input("Введіть повідомлення: ")

            key = generate_key_from_personal_data(email, phrase)
            encrypted = encrypt_message(message, key)

            print("\n🔐 Зашифровані дані:")
            print(encrypted)

        elif choice == "2":
            email = input("Введіть електронну адресу: ")
            phrase = input("Введіть секретну фразу (пароль): ")
            encrypted = input("Введіть зашифровані дані: ")

            try:
                key = generate_key_from_personal_data(email, phrase)
                decrypted = decrypt_message(encrypted, key)

                print("\n📩 Розшифроване повідомлення:")
                print(decrypted)

            except Exception:
                print("❌ Помилка розшифрування! Невірні дані або ключ.")

        elif choice == "3":
            print("Вихід.")
            break

        else:
            print("❌ Невірний вибір.")


if __name__ == "__main__":
    main()
