import re

def check_password():
    print("\n--- Перевірка пароля ---")

    name = input("Ім'я: ").lower()
    birth_date = input("Дата народження (наприклад 15.03.1995): ")
    password = input("Пароль для перевірки: ")

    score = 10
    problems = []
    recommendations = []

    # Перевірка персональних даних
    if name in password.lower():
        score -= 3
        problems.append("Пароль містить ім'я.")
        recommendations.append("Не використовуйте ім'я у паролі.")

    year = birth_date[-4:]
    if year in password:
        score -= 3
        problems.append("Пароль містить рік народження.")
        recommendations.append("Не використовуйте дату народження у паролі.")

    # Перевірка довжини
    if len(password) < 8:
        score -= 3
        problems.append("Пароль занадто короткий.")
        recommendations.append("Зробіть пароль довшим (8–12+ символів).")

    # Перевірка символів
    if not re.search(r"[A-Z]", password):
        score -= 1
        recommendations.append("Додайте великі літери.")

    if not re.search(r"[a-z]", password):
        score -= 1
        recommendations.append("Додайте малі літери.")

    if not re.search(r"\d", password):
        score -= 1
        recommendations.append("Додайте цифри.")

    if not re.search(r"[!@#$%^&*()_+=-]", password):
        score -= 1
        recommendations.append("Додайте спеціальні символи.")

    if score < 1:
        score = 1

    # Вивід
    print("\n=== Результат ===")
    print("Оцінка складності:", score, "/ 10")

    if problems:
        print("\nВиявлені проблеми:")
        for p in problems:
            print("-", p)

    print("\nРекомендації:")
    for r in recommendations:
        print("-", r)


# --- Меню ---
while True:
    print("\n=== АУДИТ ПАРОЛЯ ===")
    print("1 — Перевірити пароль")
    print("2 — Вийти")

    choice = input("Оберіть дію: ")

    if choice == "1":
        check_password()
    elif choice == "2":
        print("Завершення програми.")
        break
    else:
        print("Невірний вибір.")
