from PIL import Image
import sys

# Двобайтовий маркер, який використовується для визначення кінця прихованого повідомлення
END_MARKER = bytes([0xFF, 0x00, 0xFF, 0x00])

# Перетворює послідовність байтів у послідовність окремих бітів
def _to_bits(data_bytes):
    for byte in data_bytes:
        # Виділяємо кожен біт у байті, починаючи зі старшого
        for i in range(7, -1, -1):
            yield (byte >> i) & 1

# Об’єднує послідовність бітів назад у байти
def _from_bits(bits):
    result = bytearray()
    current = 0          # Накопичувач поточного байта
    bit_count = 0        # Кількість зібраних бітів

    for bit in bits:
        current = (current << 1) | bit
        bit_count += 1

        # Після набору 8 бітів формуємо байт
        if bit_count == 8:
            result.append(current)
            current = 0
            bit_count = 0

    return bytes(result)

# Вбудовує текстове повідомлення у зображення методом LSB
def hide_message(cover_path, stego_path, message_text):
    img = Image.open(cover_path).convert("RGB")  # Завантажуємо зображення у форматі RGB
    pixels = img.load()
    w, h = img.size

    # Кодуємо текст та додаємо службовий маркер завершення
    payload = message_text.encode("utf-8") + END_MARKER
    bits = list(_to_bits(payload))

    # Обчислюємо максимально можливу кількість бітів (по 1 біту на кожен канал RGB)
    capacity_bits = w * h * 3

    # Перевіряємо, чи достатньо місця у зображенні
    if len(bits) > capacity_bits:
        raise ValueError(
            f"Недостатній розмір зображення: потрібно {len(bits)} біт, доступно {capacity_bits}"
        )

    bit_index = 0  # Покажчик на поточний біт повідомлення

    for y in range(h):
        for x in range(w):
            if bit_index >= len(bits):
                break

            r, g, b = pixels[x, y]

            # Замінюємо молодший біт кожного кольорового каналу
            r = (r & ~1) | bits[bit_index]
            bit_index += 1

            if bit_index < len(bits):
                g = (g & ~1) | bits[bit_index]
                bit_index += 1

            if bit_index < len(bits):
                b = (b & ~1) | bits[bit_index]
                bit_index += 1

            pixels[x, y] = (r, g, b)

        if bit_index >= len(bits):
            break

    # Зберігаємо зображення з прихованим повідомленням
    img.save(stego_path, format="PNG")
    print(f"Готово. Повідомлення записано у файл: {stego_path}")
    print(f"Використано біт: {len(bits)}/{capacity_bits}, BPP: {round(len(bits)/(w*h), 3)}")

# Зчитує приховане повідомлення зі стего-зображення
def extract_message(stego_path):
    img = Image.open(stego_path).convert("RGB")
    pixels = img.load()
    w, h = img.size
    bits = []

    # Послідовно зчитуємо молодші біти з усіх каналів
    for y in range(h):
        for x in range(w):
            r, g, b = pixels[x, y]
            bits.append(r & 1)
            bits.append(g & 1)
            bits.append(b & 1)

    data = _from_bits(bits)
    end_index = data.find(END_MARKER)

    # Якщо маркер не знайдено — повідомлення відсутнє або файл змінено
    if end_index == -1:
        raise ValueError(
            "Маркер завершення не знайдено. Можливо, дані не вбудовані або файл пошкоджений."
        )

    print("Отриманий текст:")
    print(data[:end_index].decode("utf-8"))

# Точка входу для запуску з командного рядка
if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Використання:")
        print("  python app.py hide input.png output.png Ваш текст")
        print("  python app.py extract output.png")
        sys.exit(1)

    command = sys.argv[1].lower()

    try:
        if command == "hide":
            if len(sys.argv) < 5:
                print("Приклад: python app.py hide input.png output.png Ваш текст")
                sys.exit(1)

            cover, stego, msg = sys.argv[2], sys.argv[3], " ".join(sys.argv[4:])
            hide_message(cover, stego, msg)

        elif command == "extract":
            if len(sys.argv) < 3:
                print("Приклад: python app.py extract output.png")
                sys.exit(1)

            extract_message(sys.argv[2])

        else:
            print("Невідома команда:", command)
            sys.exit(1)

    except Exception as e:
        print("Помилка:", e)
        sys.exit(2)
