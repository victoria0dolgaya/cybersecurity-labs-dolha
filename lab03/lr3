from PIL import Image
import os


# Допоміжні функції
def bytes_to_bits(data: bytes) -> list[int]:
    bits = []
    for b in data:
        for i in range(7, -1, -1):
            bits.append((b >> i) & 1)
    return bits


def bits_to_bytes(bits: list[int]) -> bytes:
    out = bytearray()
    for i in range(0, len(bits), 8):
        byte = 0
        chunk = bits[i:i+8]
        for bit in chunk:
            byte = (byte << 1) | bit
        out.append(byte)
    return bytes(out)


def int_to_32bits(n: int) -> list[int]:
    # 32 біти довжини повідомлення (в байтах)
    return [(n >> i) & 1 for i in range(31, -1, -1)]


def bits32_to_int(bits: list[int]) -> int:
    n = 0
    for bit in bits:
        n = (n << 1) | bit
    return n


def file_size_bytes(path: str) -> int:
    return os.path.getsize(path)


# ЕТАП 2: hide_message()
def hide_message(input_image_path: str, output_image_path: str, message: str) -> dict:
    """
    Приховує текст у зображенні (LSB) і зберігає у PNG.
    Формат даних усередині:
    [32 біти довжина повідомлення в байтах] + [повідомлення в UTF-8]
    """
    img = Image.open(input_image_path).convert("RGB")
    pixels = list(img.getdata())

    msg_bytes = message.encode("utf-8")
    length_bits = int_to_32bits(len(msg_bytes))
    msg_bits = bytes_to_bits(msg_bytes)
    payload = length_bits + msg_bits

    capacity = len(pixels) * 3  # 1 біт у кожен канал R,G,B
    if len(payload) > capacity:
        raise ValueError(
            f"Повідомлення завелике! Потрібно {len(payload)} біт, доступно {capacity} біт."
        )

    changed_channels = 0
    changed_pixels = 0

    new_pixels = []
    bit_idx = 0

    for (r, g, b) in pixels:
        if bit_idx >= len(payload):
            new_pixels.append((r, g, b))
            continue

        original = (r, g, b)
        channels = [r, g, b]

        for c in range(3):
            if bit_idx >= len(payload):
                break
            bit = payload[bit_idx]
            bit_idx += 1

            old_val = channels[c]
            new_val = (old_val & 0xFE) | bit  # заміна молодшого біта
            if new_val != old_val:
                changed_channels += 1
            channels[c] = new_val

        new_pixel = tuple(channels)
        if new_pixel != original:
            changed_pixels += 1

        new_pixels.append(new_pixel)

    out = Image.new("RGB", img.size)
    out.putdata(new_pixels)
    out.save(output_image_path, format="PNG")

    # Аналіз розміру файлу
    before = file_size_bytes(input_image_path)
    after = file_size_bytes(output_image_path)

    return {
        "input_size_bytes": before,
        "output_size_bytes": after,
        "changed_pixels": changed_pixels,
        "changed_channels": changed_channels,
        "capacity_bits": capacity,
        "used_bits": len(payload),
    }


# ЕТАП 2: extract_message()
def extract_message(stego_image_path: str) -> str:
    """
    Витягує текст із зображення.
    Зчитує 32 біти довжини (байти), потім читає відповідну кількість бітів повідомлення.
    """
    img = Image.open(stego_image_path).convert("RGB")
    pixels = list(img.getdata())

    bits = []
    for (r, g, b) in pixels:
        bits.append(r & 1)
        bits.append(g & 1)
        bits.append(b & 1)

    length = bits32_to_int(bits[:32])  # довжина в байтах
    msg_bits_len = length * 8

    msg_bits = bits[32:32 + msg_bits_len]
    msg_bytes = bits_to_bytes(msg_bits)

    return msg_bytes.decode("utf-8", errors="replace")


# ЕТАП 4: аналіз змін
def print_analysis(stats: dict):
    print("\n=== АНАЛІЗ ЗМІН ===")
    print(f"Розмір оригіналу: {stats['input_size_bytes']} байт")
    print(f"Розмір модифікованого: {stats['output_size_bytes']} байт")
    print(f"Змінено пікселів: {stats['changed_pixels']}")
    print(f"Змінено каналів (R/G/B): {stats['changed_channels']}")
    print(f"Ємність (біт): {stats['capacity_bits']}")
    print(f"Використано (біт): {stats['used_bits']}")


# Меню 
def menu():
    print("\n=== ЛР3: Стеганографія LSB (текст у зображенні) ===")
    print("1) Приховати повідомлення у зображенні (hide_message)")
    print("2) Витягнути повідомлення із зображення (extract_message)")
    print("3) Вийти")


def main():
    while True:
        menu()
        choice = input("Обери (1-3): ").strip()

        if choice == "1":
            inp = input("Шлях до ВХІДНОГО зображення (краще PNG): ").strip()
            out = input("Шлях для ЗБЕРЕЖЕННЯ (наприклад stego.png): ").strip()
            msg = input("Введіть текст для приховування: ")

            try:
                stats = hide_message(inp, out, msg)
                print("\n✅ Повідомлення приховано успішно!")
                print_analysis(stats)
                print("\nПорада: відкрий обидва зображення — візуально різниці майже не буде (бо змінюється лише 1 біт).")
            except Exception as e:
                print(f"❌ Помилка: {e}")

        elif choice == "2":
            stego = input("Шлях до зображення зі схованим текстом (PNG): ").strip()
            try:
                msg = extract_message(stego)
                print("\n✅ Витягнуте повідомлення:")
                print(msg)
            except Exception as e:
                print(f"❌ Помилка: {e}")

        elif choice == "3":
            print("Вихід.")
            break
        else:
            print("❌ Невірний вибір.")


if __name__ == "__main__":
    main()
