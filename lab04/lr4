import base64
import hashlib
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.backends import default_backend
from cryptography.exceptions import InvalidSignature


# Хешування
def sha256(text: str) -> bytes:
    return hashlib.sha256(text.encode("utf-8")).digest()


# Ключі: збереження / завантаження
def generate_keys(private_path="private.pem", public_path="public.pem"):
    private_key = rsa.generate_private_key(
        public_exponent=65537,
        key_size=2048,
        backend=default_backend()
    )
    public_key = private_key.public_key()

    with open(private_path, "wb") as f:
        f.write(private_key.private_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PrivateFormat.PKCS8,
            encryption_algorithm=serialization.NoEncryption()
        ))

    with open(public_path, "wb") as f:
        f.write(public_key.public_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PublicFormat.SubjectPublicKeyInfo
        ))

    print(f"✅ Ключі збережено: {private_path}, {public_path}")


def load_private_key(path="private.pem"):
    with open(path, "rb") as f:
        return serialization.load_pem_private_key(f.read(), password=None, backend=default_backend())


def load_public_key(path="public.pem"):
    with open(path, "rb") as f:
        return serialization.load_pem_public_key(f.read(), backend=default_backend())


# Підпис / перевірка
def sign_text(text: str, private_path="private.pem", sig_path="signature.b64"):
    private_key = load_private_key(private_path)
    digest = sha256(text)

    signature = private_key.sign(
        digest,
        padding.PSS(
            mgf=padding.MGF1(hashes.SHA256()),
            salt_length=padding.PSS.MAX_LENGTH
        ),
        hashes.SHA256()
    )

    with open(sig_path, "w", encoding="utf-8") as f:
        f.write(base64.b64encode(signature).decode("utf-8"))

    print(f"✅ Підпис створено і збережено у {sig_path}")


def verify_text(text: str, public_path="public.pem", sig_path="signature.b64"):
    public_key = load_public_key(public_path)
    digest = sha256(text)

    with open(sig_path, "r", encoding="utf-8") as f:
        signature = base64.b64decode(f.read().strip().encode("utf-8"))

    try:
        public_key.verify(
            signature,
            digest,
            padding.PSS(
                mgf=padding.MGF1(hashes.SHA256()),
                salt_length=padding.PSS.MAX_LENGTH
            ),
            hashes.SHA256()
        )
        print("✅ Підпис ДІЙСНИЙ (текст не змінений).")
    except InvalidSignature:
        print("❌ Підпис НЕДІЙСНИЙ (текст змінений або підпис не той).")
    except FileNotFoundError:
        print("❌ Файл підпису не знайдено.")


# Меню
def menu():
    print("\n=== Меню: Спрощений цифровий підпис ===")
    print("1) Згенерувати ключі (private.pem / public.pem)")
    print("2) Підписати текст (зберегти signature.b64)")
    print("3) Перевірити підпис тексту (signature.b64)")
    print("4) Вийти")


def main():
    while True:
        menu()
        choice = input("Обери (1-4): ").strip()

        if choice == "1":
            generate_keys()

        elif choice == "2":
            text = input("Введи текст для підпису: ")
            sign_text(text)

        elif choice == "3":
            text = input("Введи текст для перевірки: ")
            verify_text(text)

        elif choice == "4":
            print("Вихід.")
            break

        else:
            print("❌ Неправильний вибір. Введи 1-4.")


if __name__ == "__main__":
    main()
